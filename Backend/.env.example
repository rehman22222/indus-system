# Server Configuration
PORT=5000
NODE_ENV=development
OTP_DEV_MODE=true

# MongoDB Atlas Configuration
MONGODB_URI=mongodb+srv://<username>:<password>@doctorappointment.srjyzfu.mongodb.net/doctorappointment?retryWrites=true&w=majority&appName=DoctorAppointment
MONGODB_DB_NAME=doctorappointment
MONGODB_AUTO_INDEX=false
MONGODB_ENSURE_INDEXES_ON_STARTUP=false
MONGODB_MIN_POOL_SIZE=0
MONGODB_MAX_POOL_SIZE=50
MONGODB_SERVER_SELECTION_TIMEOUT_MS=10000

# Free appointment-scoped WebRTC. Deploy CALL_WEB_BASE_URL over HTTPS.
VIDEO_PROVIDER=webrtc
CALL_WEB_BASE_URL=http://localhost:5173
JITSI_BASE_URL=https://meet.jit.si

# Daily.co Video Configuration (only used when VIDEO_PROVIDER=daily)
DAILY_API_KEY=your_daily_api_key
DAILY_API_URL=https://api.daily.co/v1

# Firebase Cloud Messaging
FCM_SERVER_KEY=your_fcm_server_key
FCM_PROJECT_ID=your_firebase_project_id

# Email Service (Resend)
RESEND_API_KEY=your_resend_api_key
OTP_FROM_EMAIL=noreply@yourdomain.com
OTP_FROM_NAME=INDUS Hospital
OTP_EXPIRY_MINUTES=10

# JWT Configuration
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRES_IN=3600
OTP_HASH_SECRET=your_otp_hash_secret

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=300
AUTH_RATE_LIMIT_MAX_REQUESTS=30
TRUST_PROXY=false

# Analytics Service URL
ANALYTICS_API_URL=http://localhost:8000

# Redis Cache / Socket.IO Scale-Out (optional locally, REQUIRED for multi-instance)
CACHE_ENABLED=true
CACHE_DEFAULT_TTL_SECONDS=60
REDIS_URL=
SOCKET_IO_REDIS_URL=
# Notification worker idle poll (seconds). Higher = fewer Redis commands
# (matters on Upstash free tier); delivery stays immediate. 1-60.
NOTIFICATION_POLL_SECONDS=10

# Scaling / process management
# WEB_CONCURRENCY: workers when running `node src/cluster.js` (0 = one per CPU core).
WEB_CONCURRENCY=0
# HTTP keep-alive tuning (keepAlive must be < headers to avoid proxy 502s).
SERVER_KEEP_ALIVE_TIMEOUT_MS=65000
SERVER_HEADERS_TIMEOUT_MS=66000
SERVER_REQUEST_TIMEOUT_MS=30000
SHUTDOWN_TIMEOUT_MS=15000

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:5173,http://localhost:3001
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:3001
