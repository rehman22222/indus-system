{
    "name": "hospital-backend",
    "version": "1.0.0",
    "description": "Hospital Management System Backend - Node.js + Express",
    "main": "src/server.js",
    "type": "module",
    "scripts": {
        "dev": "node src/server.js",
        "start": "node src/server.js",
        "start:cluster": "node src/cluster.js",
        "start:prod": "pm2 start ecosystem.config.cjs --env production",
        "loadtest": "node src/scripts/loadTest.js",
        "db:ensure-indexes": "node src/scripts/ensureIndexes.js",
        "db:seed": "node src/scripts/seedDemoData.js",
        "db:seed:video": "node src/scripts/seedVideoCallDemoData.js",
        "db:seed:analytics": "node src/scripts/seedAnalyticsData.js",
        "db:seed:slots": "node src/scripts/seedSlots.js",
        "db:repair:slots": "node src/scripts/repairSlotAvailability.js",
        "db:seed:all": "npm run db:seed && npm run db:seed:analytics",
        "test": "node --test src/tests/password.service.test.js",
        "lint": "eslint src/"
    },
    "dependencies": {
        "@socket.io/redis-adapter": "^8.3.0",
        "agora-token": "^2.0.5",
        "axios": "^1.6.7",
        "compression": "^1.7.4",
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "express": "^4.18.2",
        "express-rate-limit": "^7.1.5",
        "express-validator": "^7.0.1",
        "firebase-admin": "^13.10.0",
        "helmet": "^7.1.0",
        "jsonwebtoken": "^9.0.2",
        "mongoose": "^8.19.4",
        "morgan": "^1.10.0",
        "nodemailer": "^8.0.10",
        "redis": "^6.0.0",
        "resend": "^6.12.4",
        "socket.io": "^4.8.3"
    },
    "devDependencies": {
        "eslint": "^8.57.0",
        "jest": "^29.7.0",
        "nodemon": "^3.0.3"
    },
    "engines": {
        "node": ">=18.0.0"
    }
}
