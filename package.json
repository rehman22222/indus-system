{
    "name": "hospital-management-fyp",
    "version": "1.0.0",
    "description": "Hospital Management System - Final Year Project",
    "private": true,
    "scripts": {
        "dev": "concurrently --names \"BACKEND,WEB\" --prefix-colors \"blue,green\" \"npm run dev:backend\" \"npm run dev:web\"",
        "dev:https": "powershell -ExecutionPolicy Bypass -File scripts/start-dev-https.ps1",
        "web": "concurrently --names \"BACKEND,APP\" --prefix-colors \"blue,magenta\" \"npm run dev:backend\" \"npm run dev:app\"",
        "app": "npm run dev:app",
        "dev:backend": "cd Backend && node src/server.js",
        "dev:backend:watch": "cd Backend && nodemon src/server.js",
        "dev:web": "cd Frontend/Web && npm run dev",
        "dev:app": "cd Frontend/App && npm run web",
        "dev:mobile": "cd Frontend/Mobile && npm run start",
        "dev:mobile:expo-go": "cd Frontend/Mobile && npm run start:expo-go",
        "dev:analytics": "cd Backend/Analytics && python -m uvicorn api.main:app --reload",
        "build:backend": "cd Backend && echo 'No build needed for Node.js'",
        "build:web": "cd Frontend/Web && npm run build",
        "build:app": "cd Frontend/App && npm run build:web",
        "build:mobile:android:preview": "cd Frontend/Mobile && npm run build:android:preview",
        "build:mobile:android:production": "cd Frontend/Mobile && npm run build:android:production",
        "build:mobile:ios:production": "cd Frontend/Mobile && npm run build:ios:production",
        "build:all": "npm run build:web && npm run build:app",
        "type-check:app": "cd Frontend/App && npm run type-check",
        "type-check:mobile": "cd Frontend/Mobile && npm run type-check",
        "test:backend": "cd Backend && npm test",
        "test:analytics": "cd Backend/Analytics && pytest",
        "test:web": "cd Frontend/Web && npm test",
        "test:app": "cd Frontend/App && npm test",
        "install:backend": "cd Backend && npm install",
        "install:web": "cd Frontend/Web && npm install",
        "install:app": "cd Frontend/App && npm install",
        "install:mobile": "cd Frontend/Mobile && npm install",
        "deps:mobile:fix": "cd Frontend/Mobile && npm run deps:fix",
        "install:all": "npm install && npm run install:backend && npm run install:web && npm run install:app && npm run install:mobile",
        "seed:all": "cd Backend && npm run db:seed:all",
        "verify": "npm run test:backend && npm run build:web && npm run type-check:app && npm run build:app",
        "verify:mobile": "npm run type-check:mobile"
    },
    "keywords": [
        "hospital",
        "management",
        "healthcare",
        "fyp"
    ],
    "author": "",
    "license": "ISC",
    "devDependencies": {
        "concurrently": "^8.2.2"
    }
}
