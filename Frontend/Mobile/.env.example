# Public mobile app configuration.
# For production this must be your HTTPS backend API domain.
EXPO_PUBLIC_API_BASE_URL=https://api.your-domain.com
EXPO_PUBLIC_APP_NAME="Indus Hospital"

# EAS project metadata.
EAS_PROJECT_ID=
EXPO_OWNER=
EXPO_UPDATE_URL=

# Optional Firebase config file paths for production push builds.
GOOGLE_SERVICES_JSON=./google-services.json
GOOGLE_SERVICE_INFO_PLIST=./GoogleService-Info.plist

# Do not put MongoDB, Daily, Resend, Firebase Admin, JWT, or OTP secrets here.
# The native app must access those services through the Express backend only.
