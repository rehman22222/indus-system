{
  "name": "indus-mobile-native",
  "version": "1.0.0",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "start": "expo start --dev-client",
    "start:expo-go": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "deps:fix": "expo install --fix",
    "type-check": "tsc --noEmit",
    "prebuild": "expo prebuild",
    "build:android:preview": "eas build --platform android --profile preview",
    "build:android:production": "eas build --platform android --profile production",
    "build:ios:production": "eas build --platform ios --profile production",
    "submit:android": "eas submit --platform android",
    "submit:ios": "eas submit --platform ios"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.0.0",
    "@react-navigation/native": "^7.0.0",
    "@react-navigation/native-stack": "^7.0.0",
    "expo": "^56.0.0",
    "expo-build-properties": "~56.0.18",
    "expo-constants": "~56.0.17",
    "expo-dev-client": "~56.0.19",
    "expo-device": "~56.0.4",
    "expo-linking": "~56.0.13",
    "expo-notifications": "~56.0.16",
    "expo-secure-store": "~56.0.4",
    "expo-status-bar": "~56.0.4",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "^4.0.0",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@expo/ngrok": "^4.1.3",
    "@types/react": "^19.0.0",
    "dotenv": "^16.4.7",
    "eas-cli": "^16.0.0",
    "typescript": "~6.0.3"
  }
}
