{
  "name": "indus-mobile-native",
  "version": "1.0.0",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "start": "expo start --dev-client",
    "start:expo-go": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "deps:fix": "expo install --fix",
    "type-check": "tsc --noEmit",
