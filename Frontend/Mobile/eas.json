{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "APP_ENV": "development",
        "EXPO_PUBLIC_API_BASE_URL": "https://indus-system.onrender.com",
        "EXPO_PUBLIC_APP_NAME": "Indus Hospital"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "APP_ENV": "preview",
        "EXPO_PUBLIC_API_BASE_URL": "https://indus-system.onrender.com",
        "EXPO_PUBLIC_APP_NAME": "Indus Hospital"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "APP_ENV": "production",
        "EXPO_PUBLIC_API_BASE_URL": "https://indus-system.onrender.com",
        "EXPO_PUBLIC_APP_NAME": "Indus Hospital"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
