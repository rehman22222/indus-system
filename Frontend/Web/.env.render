# Loaded by `npm run dev:render` (vite --mode render). Points the doctor/patient
# WEB portal at the deployed Render backend so it shares ONE Socket.IO server with
# the installed APK — that's what lets a doctor on the laptop RING the APK on a phone.
# Everything not overridden here is inherited from .env (ML/Firebase stay local).
VITE_API_BASE_URL=https://indus-system.onrender.com
VITE_API_URL=https://indus-system.onrender.com
