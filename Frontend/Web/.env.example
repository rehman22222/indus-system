# Backend API (Express; the browser never connects directly to MongoDB)
VITE_API_BASE_URL=http://localhost:5000
VITE_API_URL=http://localhost:5000
VITE_APP_NAME="Hospital Management System"

# Firebase Configuration (for push notifications)
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
VITE_FIREBASE_VAPID_KEY=your-vapid-key

# ML Analytics API (Python backend)
VITE_ML_API_URL=http://localhost:8000
VITE_ANALYTICS_API_KEY=

# Optional dedicated Socket.IO origin. Leave blank when the deployed frontend
# reverse-proxies /socket.io to the backend.
VITE_VIDEO_SIGNAL_URL=

# Optional self-hosted coturn server for reliable calls across strict networks.
VITE_TURN_URL=
VITE_TURN_USERNAME=
VITE_TURN_CREDENTIAL=
